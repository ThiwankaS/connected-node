# ==============================================================================
# DEBIAN LINUX / ESP-IDF / NEOVIM & CLANGD GITIGNORE
# ==============================================================================

# ------------------------------------------------------------------------------
# Neovim, Ctags, and Clangd Tooling
# ------------------------------------------------------------------------------
# Ignore the compilation database containing local Debian absolute filesystem paths
compile_commands.json

# Ignore the local background indexing directory generated by the clangd server
.clangd/

# Ignore Neovim recovery, buffer swap files, and internal history
*.swp
*.swo
.netrwhist

# Ignore source code tagging indexes common in Linux development environment tools
tags
cscope.*

# ------------------------------------------------------------------------------
# ESP-IDF Build Output & Artifacts
# ------------------------------------------------------------------------------
# Ignore the build output directory containing Linux ELF binaries and object files
build/
.cache

# ------------------------------------------------------------------------------
# ESP-IDF SDK Configuration
# ------------------------------------------------------------------------------
# Ignore the prior configuration backup generated during idf.py menuconfig runs
sdkconfig.old

# Ignore external dependencies pulled down by the ESP Component Manager
managed_components/
dependencies.lock

# ------------------------------------------------------------------------------
# Debian OS Metadata
# ------------------------------------------------------------------------------
# Ignore localized directory attributes and trash artifacts typical on Linux filesystems
.directory
.Trash-*
